# .streamlit/secrets.toml
# Add these three values in your Streamlit Community Cloud dashboard:
# App Settings → Secrets → paste the contents below and fill in your values.
#
# NEVER commit this file to GitHub with real values.
# Add .streamlit/secrets.toml to your .gitignore.

GITHUB_TOKEN  = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GITHUB_REPO   = "your-org/your-repo-name"   # e.g. "acme/pharmaroi-app"
GITHUB_BRANCH = "main"
